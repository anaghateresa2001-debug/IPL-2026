-- ============================================================
-- SECTION 1: DIMENSION TABLES (Core Entities)
-- ============================================================

-- Teams
Create database if not exists IPL2026;

CREATE TABLE Teams (
    team_id         INT             PRIMARY KEY,
    team_name       VARCHAR(100)    NOT NULL UNIQUE,
    short_name      VARCHAR(5)      NOT NULL,
    home_city       VARCHAR(100),
    home_venue_id   INT,            -- FK added after Venues table
    coach           VARCHAR(100),
    captain_player_id INT,          -- FK added after Players table
    jersey_color    VARCHAR(50),
    titles_won      INT             DEFAULT 0,
    created_at      DATETIME        DEFAULT CURRENT_TIMESTAMP
);

-- Venues
CREATE TABLE Venues (
    venue_id        INT             PRIMARY KEY,
    venue_name      VARCHAR(150)    NOT NULL,
    city            VARCHAR(100)    NOT NULL,
    state           VARCHAR(100),
    capacity        INT,
    pitch_type      VARCHAR(50),    -- 'Flat', 'Spin-friendly', 'Pace-friendly', 'Balanced'
    avg_first_innings_score INT,
    created_at      DATETIME        DEFAULT CURRENT_TIMESTAMP
);

-- Players
CREATE TABLE Players (
    player_id       INT             PRIMARY KEY,
    full_name       VARCHAR(150)    NOT NULL,
    short_name      VARCHAR(80),
    team_id         INT             NOT NULL,
    role            VARCHAR(30)     NOT NULL,   -- 'Batsman', 'Bowler', 'All-rounder', 'WK-Batsman'
    batting_style   VARCHAR(30),               -- 'Right-hand', 'Left-hand'
    bowling_style   VARCHAR(60),               -- 'Right-arm Fast', 'Left-arm Spin', etc.
    nationality     VARCHAR(60)     NOT NULL,
    is_overseas     BIT             DEFAULT 0,
    base_price_cr   DECIMAL(5,2),              -- In Crore INR
    sold_price_cr   DECIMAL(6,2),
    age             INT,
    debut_year      INT,
    is_active       BIT             DEFAULT 1,
    created_at      DATETIME        DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT FK_Players_Teams FOREIGN KEY (team_id) REFERENCES Teams(team_id)
);

-- Add deferred FKs on Teams now that Players exists
ALTER TABLE Teams
    ADD CONSTRAINT FK_Teams_Captain FOREIGN KEY (captain_player_id) REFERENCES Players(player_id);

ALTER TABLE Teams
    ADD CONSTRAINT FK_Teams_Venue FOREIGN KEY (home_venue_id) REFERENCES Venues(venue_id);

-- Date Dimension (for Power BI time intelligence)
CREATE TABLE Dim_Date (
    date_id         INT             PRIMARY KEY,   -- Format: YYYYMMDD
    full_date       DATE            NOT NULL UNIQUE,
    day_of_week     VARCHAR(15),
    day_no          INT,
    week_no         INT,
    month_no        INT,
    month_name      VARCHAR(15),
    quarter         INT,
    year            INT,
    is_weekend      BIT             DEFAULT 0,
    is_ipl_matchday BIT             DEFAULT 0
);


-- ============================================================
-- SECTION 2: MATCH FACT TABLES
-- ============================================================

-- Matches
CREATE TABLE Matches (
    match_id            INT             PRIMARY KEY,
    date_id             INT             NOT NULL,   -- FK to Dim_Date
    venue_id            INT             NOT NULL,
    match_type          VARCHAR(20)     NOT NULL,   -- 'League', 'Qualifier 1', 'Eliminator', 'Qualifier 2', 'Final'
    match_no            INT,                        -- Match number in season
    team1_id            INT             NOT NULL,
    team2_id            INT             NOT NULL,
    toss_winner_id      INT,
    toss_decision       VARCHAR(10),                -- 'Bat', 'Field'
    winner_team_id      INT,
    win_type            VARCHAR(20),                -- 'Runs', 'Wickets', 'Super Over', 'No Result'
    win_margin          INT,
    dl_applied          BIT             DEFAULT 0,  -- Duckworth-Lewis
    mom_player_id       INT,                        -- Man of the Match
    stadium_condition   VARCHAR(30),                -- 'Day', 'Day-Night', 'Night'
    created_at          DATETIME        DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT FK_Matches_Date     FOREIGN KEY (date_id)          REFERENCES Dim_Date(date_id),
    CONSTRAINT FK_Matches_Venue    FOREIGN KEY (venue_id)          REFERENCES Venues(venue_id),
    CONSTRAINT FK_Matches_Team1    FOREIGN KEY (team1_id)          REFERENCES Teams(team_id),
    CONSTRAINT FK_Matches_Team2    FOREIGN KEY (team2_id)          REFERENCES Teams(team_id),
    CONSTRAINT FK_Matches_Winner   FOREIGN KEY (winner_team_id)    REFERENCES Teams(team_id),
    CONSTRAINT FK_Matches_Toss     FOREIGN KEY (toss_winner_id)    REFERENCES Teams(team_id),
    CONSTRAINT FK_Matches_MOM      FOREIGN KEY (mom_player_id)     REFERENCES Players(player_id)
);

-- Match Team Stats (Innings Summary per team per match)
CREATE TABLE MatchTeamStats (
    stat_id         INT             PRIMARY KEY,
    match_id        INT             NOT NULL,
    team_id         INT             NOT NULL,
    innings_no      INT             NOT NULL,   -- 1 or 2
    total_runs      INT             DEFAULT 0,
    wickets_lost    INT             DEFAULT 0,
    overs_faced     DECIMAL(5,1),               -- e.g. 20.0, 19.3
    extras          INT             DEFAULT 0,
    wides           INT             DEFAULT 0,
    no_balls        INT             DEFAULT 0,
    run_rate        DECIMAL(5,2),               -- Computed: runs / overs
    powerplay_runs  INT,                        -- Overs 1-6
    middle_runs     INT,                        -- Overs 7-15
    death_runs      INT,                        -- Overs 16-20
    highest_partnership INT,
    CONSTRAINT FK_MTS_Match  FOREIGN KEY (match_id) REFERENCES Matches(match_id),
    CONSTRAINT FK_MTS_Team   FOREIGN KEY (team_id)  REFERENCES Teams(team_id),
    CONSTRAINT UQ_MTS        UNIQUE (match_id, team_id, innings_no)
);


-- ============================================================
-- SECTION 3: PLAYER PERFORMANCE TABLES
-- ============================================================

-- Batting Stats (per player per match)
CREATE TABLE BattingStats (
    stat_id         INT             PRIMARY KEY,
    match_id        INT             NOT NULL,
    player_id       INT             NOT NULL,
    team_id         INT             NOT NULL,
    innings_no      INT             NOT NULL,
    batting_position INT,
    runs            INT             DEFAULT 0,
    balls_faced     INT             DEFAULT 0,
    fours           INT             DEFAULT 0,
    sixes           INT             DEFAULT 0,
    is_out          BIT             DEFAULT 1,
    dismissal_type  VARCHAR(30),                -- 'Caught', 'Bowled', 'LBW', 'Run Out', 'Stumped', 'Not Out'
    dismissed_by    INT,                        -- bowler player_id
    strike_rate     DECIMAL(6,2),               -- (runs/balls)*100
    is_fifty        BIT             DEFAULT 0,
    is_hundred      BIT             DEFAULT 0,
    CONSTRAINT FK_Bat_Match  FOREIGN KEY (match_id)  REFERENCES Matches(match_id),
    CONSTRAINT FK_Bat_Player FOREIGN KEY (player_id) REFERENCES Players(player_id),
    CONSTRAINT FK_Bat_Team   FOREIGN KEY (team_id)   REFERENCES Teams(team_id),
    CONSTRAINT UQ_Bat        UNIQUE (match_id, player_id, innings_no)
);

-- Bowling Stats (per player per match)
CREATE TABLE BowlingStats (
    stat_id         INT             PRIMARY KEY,
    match_id        INT             NOT NULL,
    player_id       INT             NOT NULL,
    team_id         INT             NOT NULL,
    innings_no      INT             NOT NULL,
    overs_bowled    DECIMAL(4,1),               -- e.g. 4.0, 3.3
    maidens         INT             DEFAULT 0,
    runs_given      INT             DEFAULT 0,
    wickets         INT             DEFAULT 0,
    wides           INT             DEFAULT 0,
    no_balls        INT             DEFAULT 0,
    economy         DECIMAL(5,2),               -- runs_given / overs_bowled
    dot_balls       INT             DEFAULT 0,
    powerplay_wkts  INT             DEFAULT 0,
    death_wkts      INT             DEFAULT 0,
    CONSTRAINT FK_Bowl_Match  FOREIGN KEY (match_id)  REFERENCES Matches(match_id),
    CONSTRAINT FK_Bowl_Player FOREIGN KEY (player_id) REFERENCES Players(player_id),
    CONSTRAINT FK_Bowl_Team   FOREIGN KEY (team_id)   REFERENCES Teams(team_id),
    CONSTRAINT UQ_Bowl        UNIQUE (match_id, player_id, innings_no)
);

-- Fielding Stats (per player per match)
CREATE TABLE FieldingStats (
    stat_id         INT             PRIMARY KEY,
    match_id        INT             NOT NULL,
    player_id       INT             NOT NULL,
    team_id         INT             NOT NULL,
    catches         INT             DEFAULT 0,
    run_outs        INT             DEFAULT 0,
    stumpings       INT             DEFAULT 0,
    dropped_catches INT             DEFAULT 0,
    CONSTRAINT FK_Field_Match  FOREIGN KEY (match_id)  REFERENCES Matches(match_id),
    CONSTRAINT FK_Field_Player FOREIGN KEY (player_id) REFERENCES Players(player_id),
    CONSTRAINT FK_Field_Team   FOREIGN KEY (team_id)   REFERENCES Teams(team_id),
    CONSTRAINT UQ_Field        UNIQUE (match_id, player_id)
);

-- Ball by Ball (Most granular — optional for phase analysis)
CREATE TABLE BallByBall (
    ball_id         BIGINT          PRIMARY KEY,
    match_id        INT             NOT NULL,
    innings_no      INT             NOT NULL,
    over_no         INT             NOT NULL,   -- 1 to 20
    ball_no         INT             NOT NULL,   -- 1 to 6 (+ extras)
    batsman_id      INT             NOT NULL,
    non_striker_id  INT,
    bowler_id       INT             NOT NULL,
    runs_scored     INT             DEFAULT 0,
    extras          INT             DEFAULT 0,
    is_wide         BIT             DEFAULT 0,
    is_no_ball      BIT             DEFAULT 0,
    is_boundary     BIT             DEFAULT 0,  -- 4 runs
    is_six          BIT             DEFAULT 0,  -- 6 runs
    is_dot_ball     BIT             DEFAULT 0,
    is_wicket       BIT             DEFAULT 0,
    dismissal_type  VARCHAR(30),
    fielder_id      INT,                        -- player who took catch/run-out
    cumulative_runs INT,                        -- Running total at that ball
    match_phase     VARCHAR(15),                -- 'Powerplay', 'Middle', 'Death'
    CONSTRAINT FK_BBB_Match    FOREIGN KEY (match_id)      REFERENCES Matches(match_id),
    CONSTRAINT FK_BBB_Batsman  FOREIGN KEY (batsman_id)    REFERENCES Players(player_id),
    CONSTRAINT FK_BBB_Bowler   FOREIGN KEY (bowler_id)     REFERENCES Players(player_id),
    CONSTRAINT FK_BBB_Fielder  FOREIGN KEY (fielder_id)    REFERENCES Players(player_id),
    CONSTRAINT UQ_BBB          UNIQUE (match_id, innings_no, over_no, ball_no)
);


