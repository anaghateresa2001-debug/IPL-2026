-- SECTION 6: USEFUL VIEWS (Pre-built for Power BI Import)
-- ============================================================

-- Orange Cap Leaderboard
CREATE VIEW vw_OrangeCap AS
SELECT
    p.player_id,
    p.full_name,
    t.short_name                        AS team,
    SUM(b.runs)                         AS total_runs,
    SUM(b.balls_faced)                  AS total_balls,
    COUNT(b.stat_id)                    AS innings,
    MAX(b.runs)                         AS highest_score,
    SUM(b.fours)                        AS total_fours,
    SUM(b.sixes)                        AS total_sixes,
    SUM(CASE WHEN b.is_fifty = 1 THEN 1 ELSE 0 END) AS fifties,
    SUM(CASE WHEN b.is_hundred = 1 THEN 1 ELSE 0 END) AS hundreds,
    ROUND(SUM(b.runs) * 100.0 / NULLIF(SUM(b.balls_faced), 0), 2) AS strike_rate,
    ROUND(SUM(b.runs) * 1.0 / NULLIF(COUNT(b.stat_id), 0), 2)     AS avg_runs
FROM BattingStats b
JOIN Players p ON b.player_id = p.player_id
JOIN Teams t   ON p.team_id   = t.team_id
GROUP BY p.player_id, p.full_name, t.short_name;

-- Purple Cap Leaderboard
CREATE VIEW vw_PurpleCap AS
SELECT
    p.player_id,
    p.full_name,
    t.short_name                        AS team,
    SUM(bw.wickets)                     AS total_wickets,
    SUM(bw.overs_bowled)                AS total_overs,
    SUM(bw.runs_given)                  AS total_runs_given,
    SUM(bw.maidens)                     AS total_maidens,
    SUM(bw.dot_balls)                   AS total_dots,
    ROUND(SUM(bw.runs_given) / NULLIF(SUM(bw.overs_bowled), 0), 2) AS economy,
    ROUND(SUM(bw.overs_bowled) * 6.0 / NULLIF(SUM(bw.wickets), 0), 2) AS strike_rate
FROM BowlingStats bw
JOIN Players p ON bw.player_id = p.player_id
JOIN Teams t   ON p.team_id    = t.team_id
GROUP BY p.player_id, p.full_name, t.short_name;

-- Team Win/Loss Summary
CREATE VIEW vw_TeamSummary AS
SELECT
    t.team_id,
    t.team_name,
    t.short_name,
    COUNT(m.match_id)                                           AS matches_played,
    SUM(CASE WHEN m.winner_team_id = t.team_id THEN 1 ELSE 0 END) AS wins,
    SUM(CASE WHEN m.winner_team_id != t.team_id AND m.win_type != 'No Result' THEN 1 ELSE 0 END) AS losses,
    SUM(CASE WHEN m.win_type = 'No Result' THEN 1 ELSE 0 END)  AS no_results,
    ROUND(SUM(CASE WHEN m.winner_team_id = t.team_id THEN 1.0 ELSE 0 END) / NULLIF(COUNT(m.match_id), 0) * 100, 1) AS win_pct
FROM Teams t
LEFT JOIN Matches m ON (m.team1_id = t.team_id OR m.team2_id = t.team_id)
GROUP BY t.team_id, t.team_name, t.short_name;

-- Phase-wise Batting Analysis (Powerplay / Middle / Death)
CREATE VIEW vw_PhaseAnalysis AS
SELECT
    m.match_id,
    t.short_name                    AS team,
    b.match_phase,
    SUM(b.runs_scored)              AS phase_runs,
    COUNT(b.ball_id)                AS balls,
    SUM(CASE WHEN b.is_wicket = 1 THEN 1 ELSE 0 END) AS wickets,
    SUM(CASE WHEN b.is_boundary = 1 THEN 1 ELSE 0 END) AS fours,
    SUM(CASE WHEN b.is_six = 1 THEN 1 ELSE 0 END) AS sixes,
    SUM(CASE WHEN b.is_dot_ball = 1 THEN 1 ELSE 0 END) AS dots
FROM BallByBall b
JOIN Matches m   ON b.match_id   = m.match_id
JOIN Players bat ON b.batsman_id = bat.player_id
JOIN Teams t     ON bat.team_id  = t.team_id
GROUP BY m.match_id, t.short_name, b.match_phase;

-- Venue Stats Summary
CREATE VIEW vw_VenueStats AS
SELECT
    v.venue_id,
    v.venue_name,
    v.city,
    v.pitch_type,
    COUNT(m.match_id)               AS matches_hosted,
    AVG(s1.total_runs)              AS avg_first_innings_score,
    AVG(s2.total_runs)              AS avg_second_innings_score,
    SUM(CASE WHEN m.toss_decision = 'Bat' AND m.toss_winner_id = m.winner_team_id THEN 1 ELSE 0 END) AS bat_first_wins,
    SUM(CASE WHEN m.toss_decision = 'Field' AND m.toss_winner_id = m.winner_team_id THEN 1 ELSE 0 END) AS field_first_wins
FROM Venues v
LEFT JOIN Matches m       ON v.venue_id = m.venue_id
LEFT JOIN MatchTeamStats s1 ON m.match_id = s1.match_id AND s1.innings_no = 1
LEFT JOIN MatchTeamStats s2 ON m.match_id = s2.match_id AND s2.innings_no = 2
GROUP BY v.venue_id, v.venue_name, v.city, v.pitch_type;

